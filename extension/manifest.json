{
  "manifest_version": 3,
  "name": "Kevi - Sales Intelligence",
  "version": "1.0.0",
  "description": "Real-time visibility into your sales activity. Track keystrokes and focus time to improve productivity.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kevi - Sales Intelligence"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
